# ---- Server configuration ----
NODE_ENV=development
PORT=4000

# Optional: absolute path to the SQLite file.
# Set this on deployment platforms to point at a persistent volume so data
# survives redeploys. Leave unset in development (defaults to server/src/db/).
# Example for Render: DB_PATH=/data/app.sqlite
# DB_PATH=

# Origin allowed by CORS (the client URL). Dev default shown.
CLIENT_ORIGIN=http://localhost:5173

# JWT signing secret — use a long random string (e.g. `openssl rand -hex 32`)
# Must be at least 16 characters or the server refuses to start.
JWT_SECRET=replace-with-a-long-random-string

# ---- Admin credentials ----
# Username for the admin dashboard
ADMIN_USERNAME=demo
# bcrypt hash of the admin password. Generate it with:
#   npm --prefix server run hash-password -- "your-plain-password"
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash

# ---- Gmail SMTP (Nodemailer) ----
# The Gmail account used to SEND notification emails
GMAIL_USER=demo@example.com
# A Gmail App Password (NOT your normal password). See README for how to generate.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Where contact-form notifications are delivered (can be changed in Settings)
ADMIN_NOTIFICATION_EMAIL=demo@example.com
